@startuml CurrencyCommand
hide footbox

actor User

participant ":Finbro" as Finbro
participant ":Ui" as Ui
participant ":Parser" as Parser
participant "c:CurrencyCommand" as CurrencyCommand
participant ":ExpenseList" as ExpenseList
participant "CurrencyRateTable" as CurrencyRateTable

activate Finbro
Finbro -> Ui : readCommand()
activate Ui
User -> Ui : type "currency ..."
Ui --> Finbro : input
deactivate Ui


Finbro -> Parser : parse(input)
activate Parser

create CurrencyCommand
Parser -> CurrencyCommand : new CurrencyCommand()
activate CurrencyCommand
CurrencyCommand --> Parser : c
deactivate CurrencyCommand

Parser --> Finbro : c
deactivate Parser

Finbro -> CurrencyCommand : execute(expenseList, ui, storage)
activate CurrencyCommand

CurrencyCommand -> ExpenseList : isEmpty()
activate ExpenseList
ExpenseList --> CurrencyCommand : isEmpty
deactivate ExpenseList

alt expense list is empty
    CurrencyCommand --> Finbro : throw FinbroException("No expenses available.")
    deactivate CurrencyCommand

    Finbro -> Ui : showError("No expenses available.")
    activate Ui
    Ui --> Finbro
    deactivate Ui

else expense list is not empty
    CurrencyCommand -> Ui : showEnterSourceCurrencyPrompt()
    activate Ui
    Ui --> CurrencyCommand
    deactivate Ui

    CurrencyCommand -> Ui : readCommand()
    activate Ui
    User -> Ui : enter source currency
    Ui --> CurrencyCommand : fromCurrency
    deactivate Ui

    CurrencyCommand -> Ui : showEnterTargetCurrencyPrompt()
    activate Ui
    Ui --> CurrencyCommand
    deactivate Ui

    CurrencyCommand -> Ui : readCommand()
    activate Ui
    User -> Ui : enter target currency
    Ui --> CurrencyCommand : toCurrency
    deactivate Ui

    alt fromCurrency equals toCurrency
        CurrencyCommand -> Ui : showNoConversionNeeded(fromCurrency)
        activate Ui
        Ui --> CurrencyCommand
        deactivate Ui

        CurrencyCommand --> Finbro : return
        deactivate CurrencyCommand

    else different currencies
        CurrencyCommand -> CurrencyRateTable : isUnsupportedCurrency(fromCurrency)
        activate CurrencyRateTable
        CurrencyRateTable --> CurrencyCommand : boolean
        deactivate CurrencyRateTable

        CurrencyCommand -> CurrencyRateTable : isUnsupportedCurrency(toCurrency)
        activate CurrencyRateTable
        CurrencyRateTable --> CurrencyCommand : boolean
        deactivate CurrencyRateTable

        alt either currency unsupported
            CurrencyCommand -> CurrencyRateTable : getSupportedCurrencies()
            activate CurrencyRateTable
            CurrencyRateTable --> CurrencyCommand : supportedCurrencies
            deactivate CurrencyRateTable

            CurrencyCommand --> Finbro : throw FinbroException("Unsupported currency. Supported currencies: ...")
            deactivate CurrencyCommand

            Finbro -> Ui : showError(...)
            activate Ui
            Ui --> Finbro
            deactivate Ui

        else both currencies supported
            CurrencyCommand -> ExpenseList : getAll()
            activate ExpenseList
            ExpenseList --> CurrencyCommand : expenses
            deactivate ExpenseList

            CurrencyCommand -> Ui : showAllExpenses(expenses)
            activate Ui
            Ui --> CurrencyCommand
            deactivate Ui

            CurrencyCommand -> Ui : showChooseExpenseEntryPrompt()
            activate Ui
            Ui --> CurrencyCommand
            deactivate Ui

            CurrencyCommand -> Ui : readCommand()
            activate Ui
            User -> Ui : enter expense index
            Ui --> CurrencyCommand : input
            deactivate Ui

            CurrencyCommand -> ExpenseList : size()
            activate ExpenseList
            ExpenseList --> CurrencyCommand : size
            deactivate ExpenseList

            alt invalid number format or index out of range
                CurrencyCommand --> Finbro : throw FinbroException("Invalid entry number." / "Entry out of range.")
                deactivate CurrencyCommand

                Finbro -> Ui : showError(...)
                activate Ui
                Ui --> Finbro
                deactivate Ui

            else valid index
                CurrencyCommand -> ExpenseList : get(index - 1)
                activate ExpenseList
                ExpenseList --> CurrencyCommand : expense
                deactivate ExpenseList

                CurrencyCommand -> CurrencyRateTable : convert(expense.amount(), fromCurrency, toCurrency)
                activate CurrencyRateTable
                CurrencyRateTable --> CurrencyCommand : convertedAmount
                deactivate CurrencyRateTable

                CurrencyCommand -> Ui : showCurrencyConversionResult(index, originalAmount, fromCurrency, toCurrency, convertedAmount)
                activate Ui
                Ui --> CurrencyCommand
                deactivate Ui

                CurrencyCommand --> Finbro : return
                deactivate CurrencyCommand
            end
        end
    end
end

deactivate Finbro
@enduml